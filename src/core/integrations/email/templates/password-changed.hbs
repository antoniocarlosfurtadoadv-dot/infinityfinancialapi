<html lang='pt-BR'>

  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap'
      rel='stylesheet'
    />
    <link
      rel='stylesheet'
      href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css'
    />
    <title>Senha atualizada</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #ffffff;
        font-family: 'Poppins', Arial, Helvetica, sans-serif;
      }

      .container {
        max-width: 620px;
        margin: 0 auto;
        background: #ffffff;
        border-left: 1px solid #ededed;
        border-right: 1px solid #ededed;
      }

      .header {
        text-align: center;
        padding: 32px 48px;
        border-bottom: 1px solid #ededed;
      }

      .logo {
        max-width: 94px;
        height: auto;
      }

      .hero {
        text-align: center;
        height: 316px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        background-image: url('https://pub-00365c6f18d64e1f962879394176d9e9.r2.dev/public/background-others.png');
        background-size: contain;
        background-position: center;
        background-repeat: no-repeat;
      }

      .hero h1 {
        font-size: 40px;
        color: #071c5f;
        font-weight: 600;
        margin: 0;
      }

      .iconHero {
        width: 153px;
        height: 127px;
        margin: auto;
      }

      .content {
        padding: 0 40px;
        color: #071c5f;
      }

      .content p {
        margin: 48px 0 12px 0;
        line-height: 1.6;
        font-size: 15px;
      }

      .bold {
        font-weight: bold;
        color: #071c5f;
      }

      .fields {
        margin-top: 20px;
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .field {
        padding: 20px 40px 0;
        text-align: center;
      }

      .field span {
        font-size: 16px;
        color: #5d678a;
        display: block;
        margin-bottom: 8px;
      }

      .box {
        background: #f6f6fa;
        padding: 16px;
        border: 1px solid #ebedf0;
        border-radius: 6px;
        color: #071c5f;
        font-size: 20px;
        word-break: break-word;
      }

      .message {
        font-weight: 700;
        font-size: 18px;
      }

      .details-card {
        background: #f6f6fa;
        padding: 16px;
        border: 1px solid #ebedf0;
        border-radius: 6px;
        color: #071c5f;
      }

      .details-title {
        margin: 0 0 12px 0;
        color: #071c5f;
        font-size: 18px;
        font-weight: 700;
        text-align: left;
      }

      .details-row {
        display: table;
        width: 100%;
        border-collapse: collapse;
        margin: 0;
      }

      .details-item {
        display: table-row;
      }

      .details-label,
      .details-value {
        display: table-cell;
        padding: 10px 0;
        vertical-align: top;
        font-size: 14px;
        line-height: 1.5;
        border-bottom: 1px solid #ebedf0;
      }

      .details-label {
        width: 42%;
        color: #5d678a;
        font-weight: 600;
        text-align: left;
      }

      .details-value {
        color: #071c5f;
        text-align: right;
        font-weight: 600;
        word-break: break-word;
      }

      .details-item:last-child .details-label,
      .details-item:last-child .details-value {
        border-bottom: none;
      }

      .alert {
        margin: 48px 40px;
        padding: 12px 8px;
        border-radius: 6px;
        text-align: center;
        color: #444950;
        font-size: 14px;
        line-height: 1.5;
      }

      .alert-danger {
        background: #FEF2F2;
        color: #CC1F1F;
      }

      .button-container {
        margin-top: 48px;
        text-align: center;
        width: 100%;
        display: flex;
        justify-content: center;
      }

      .button {
        display: inline-block;
        background: #023dff;
        color: #ffffff !important;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 999px;
        font-weight: bold;
        font-size: 16px;
        width: 322px;
      }

      .expires {
        text-align: center;
        font-size: 14px;
        color: #8a90a8;
        margin: 48px 0px;
      }

      .footer {
        border-top: 1px solid #ededed;
        padding: 26px;
        text-align: center;
      }

      .logo-small {
        max-width: 80px;
        height: auto;
        margin-bottom: 10px;
      }

      .footer p {
        font-size: 14px;
        color: #4b567c;
        margin: 0 0 10px 0;
        line-height: 1.5;
      }

      .team {
        font-weight: bold;
        color: #1a2757;
      }

      .footer a {
        color: #4b567c;
        text-decoration: none;
      }

      .footer-bottom {
        border-top: 1px solid #ededed;
        text-align: center;
        padding: 18px;
      }

      .footer-bottom p {
        font-size: 12px;
        color: #8a90a8;
        margin: 0 0 4px 0;
        line-height: 1.5;
      }

      @media only screen and (max-width: 640px) {
        .container {
          width: 100% !important;
          border-left: none;
          border-right: none;
        }

        .content,
        .field {
          padding-left: 20px;
          padding-right: 20px;
        }

        .alert {
          margin-left: 20px;
          margin-right: 20px;
        }

        .hero h1 {
          font-size: 51px;
        }

        .button {
          padding: 12px 24px;
          width: 322px;
        }
      }
    </style>
  </head>

  <body>
    <div class='container'>

      <div class='header'>
        <img
          src='https://pub-00365c6f18d64e1f962879394176d9e9.r2.dev/public/Logo%20(1).png'
          alt='Atlas Ecolab'
          class='logo'
        />
      </div>

      <div class='hero'>
        <img
          src='https://pub-00365c6f18d64e1f962879394176d9e9.r2.dev/public/senha.png'
          class='iconHero'
          alt='Security icon'
        />
        <h1>Senha atualizada</h1>
      </div>

      <div class='content'>
        <p>Olá, <span class='bold'>{{userName}}!</span></p>

        <p>
          Sua senha foi alterada com sucesso. Você já pode acessar sua conta com
          a nova senha.
        </p>
        <p>
          Veja os detalhes abaixo para confirmar se esta atualização foi
          realizada por você.
        </p>

      </div>

      <div class='fields'>
        <div class='field'>
          <div class='details-card'>
            <p class='details-title'>Atualização</p>

            <div class='details-row'>
              {{#if accessTime}}
                <div class='details-item'>
                  <div class='details-label'>Data e Hora</div>
                  <div class='details-value'>{{accessTime}}</div>
                </div>
              {{/if}}

              {{#if deviceInfo}}
                <div class='details-item'>
                  <div class='details-label'>Dispositivo</div>
                  <div class='details-value'>{{deviceInfo}}</div>
                </div>
              {{/if}}

              {{#if location}}
                <div class='details-item'>
                  <div class='details-label'>Localização</div>
                  <div class='details-value'>{{location}}</div>
                </div>
              {{/if}}

              {{#if ipAddress}}
                <div class='details-item'>
                  <div class='details-label'>Endereço IP</div>
                  <div class='details-value'>{{ipAddress}}</div>
                </div>
              {{/if}}
            </div>
          </div>
        </div>
      </div>

      {{#if true}}
        <div class='button-container'>
          <a href='{{securityUrl}}' class='button'>Entrar na conta</a>
        </div>
      {{/if}}

      <div class='alert alert-danger'>
        Não foi você? Acione o Master ou nosso time imediatamente!
      </div>


      <div class='footer'>
        <img
          src='https://pub-00365c6f18d64e1f962879394176d9e9.r2.dev/public/Logo%20(1).png'
          alt='Atlas Ecolab'
          class='logo-small'
        />

        <p>
          Se precisar de ajuda ou tiver qualquer dúvida, fale com nosso time.
        </p>

        <p class='team'>Equipe Atlas Ecolab</p>

        <a href='mailto:contato@atlasecolab.com.br'>
          contato@atlasecolab.com.br
        </a>
      </div>

      <div class='footer-bottom'>
        <p>© {{year}} Atlas Ecolab. Todos os direitos reservados.</p>
        <p>Esta é uma mensagem automática, não responda a este e-mail.</p>
      </div>

    </div>
  </body>

</html>